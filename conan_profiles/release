include(default)

[settings]
build_type=Release
compiler.cppstd=gnu23
compiler.libcxx=libstdc++11
# compiler.cstd intentionally omitted — not in conanfile.py settings,
# including it changes Conan package ID hash causing binary mismatches.

[buildenv]
CC=gcc
CXX=g++

[conf]
tools.cmake.cmaketoolchain:generator=Ninja
tools.build:jobs=8
tools.build:cxxflags=["-D_GLIBCXX_ASSERTIONS"]
