#pragma once

/// @file version.hpp
/// @brief CMake-generated version information for Muscovite Harbor

namespace @VERSION_NAMESPACE@ {

/// Full version string (e.g., "0.1.0")
inline constexpr const char* kVersion = "@PROJECT_VERSION@";

/// Major version component
inline constexpr int kVersionMajor = @PROJECT_VERSION_MAJOR@;

/// Minor version component
inline constexpr int kVersionMinor = @PROJECT_VERSION_MINOR@;

/// Patch version component
inline constexpr int kVersionPatch = @PROJECT_VERSION_PATCH@;

/// Git commit SHA (short form)
inline constexpr const char* kGitSha = "@GIT_SHA@";

/// CMake build type (Debug, Release, etc.)
inline constexpr const char* kBuildType = "@CMAKE_BUILD_TYPE@";

/// ISO 8601 UTC timestamp of build
inline constexpr const char* kBuildTime = "@BUILD_TIMESTAMP@";

} // namespace @VERSION_NAMESPACE@
